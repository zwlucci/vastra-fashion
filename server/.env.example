DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/vastra_db
JWT_SECRET=replace-this-with-a-long-random-secret

# Listen on every local network interface for same-router Ethernet/Wi-Fi development.
HOST=0.0.0.0
PORT=5000

# The Vite port is used to safely allow localhost and private-LAN origins.
FRONTEND_PORT=5173
CLIENT_URL=http://localhost:5173
# Optional comma-separated additional origins, for example:
# CLIENT_URLS=http://127.0.0.1:5173,http://192.168.1.25:5173
CLIENT_URLS=
SERVER_PUBLIC_URL=http://localhost:5000
CART_RESERVATION_MINUTES=15

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=my_email@gmail.com
EMAIL_PASS=my_gmail_app_password
EMAIL_FROM="VASTRA <my_email@gmail.com>"
PASSWORD_RESET_URL=http://localhost:5173/reset-password

# Development-only saved test cards. Never enable this for real payment data.
ENABLE_DEMO_SAVED_CARDS=false
DEMO_CARD_NUMBERS=4242424242424242,5555555555554444,378282246310005
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DEMO_CARD_ENCRYPTION_KEY=
