# Optional. Leave blank to use the Vite same-origin development proxy.
# Set this only when the API is hosted at a different origin (for example, production):
# VITE_API_URL=http://192.168.1.25:5000/api
VITE_API_URL=
# Port used by the Vite development proxy on this computer.
VITE_API_PORT=5000
# Optional complete proxy target; defaults to http://127.0.0.1:VITE_API_PORT.
# VITE_DEV_BACKEND_URL=http://127.0.0.1:5000
